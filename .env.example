# --- DEPLOYMENT CONFIGURATION ---
# Replace these with your server's IP address or domain

# The public URL where you view the frontend (e.g. http://1.2.3.4:3001)
FRONTEND_URL=http://localhost:3001

# The public URL where your backend is reachable (e.g. http://1.2.3.4:4001)
BACKEND_URL=http://localhost:4001

# --- n8n CONFIGURATION ---
N8N_YOUTUBE_CHAT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/...
N8N_USERNAME=your_n8n_username
N8N_PASSWORD=your_n8n_password
